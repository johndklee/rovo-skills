# Your Atlassian site, e.g. https://your-domain.atlassian.net
ATLASSIAN_SITE_URL=https://your-domain.atlassian.net

# Jira project to read sprint data from
JIRA_PROJECT_KEY=PROJ

# Confluence space (and optional parent page) to publish the sprint report under
CONFLUENCE_SPACE_KEY=SPACE
CONFLUENCE_PARENT_PAGE_ID=

# Rovo agent to invoke (created in Atlassian Rovo)
ROVO_AGENT_ID=

# Auth for calling the Rovo agent
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=
